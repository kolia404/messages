
generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"] 
}

datasource db {
  provider = "postgresql" 
  url      = env("DATABASE_URL")
}

// ---------------- Enums ---------------- //
enum Role {
  ADMIN
  DOCTOR
}

enum ThesisType {
  MASTER
  PHD
}

enum ThesisStatus {
  PENDING      
  IN_PROGRESS  
  APPROVED     
}

// ---------------- Models ---------------- //

model User {
  id            String   @id @default(cuid())
  name          String
  role          Role     @default(DOCTOR)
  academicTitle String   @default("دكتور") 
  doctorCode    String?  @unique 
  password      String   
  tempPassword  String?  
  createdAt     DateTime @default(now())
  image         String?
}
model FacultyDoctor {
  id            String   @id @default(cuid())
  name          String
  academicTitle String   @default("دكتور") 
  supervisions  Supervision[]
  promotions    Promotion[]
  createdAt     DateTime @default(now())
}
model ExternalExaminer {
  id             String   @id @default(cuid())
  name           String
  universityName String
  academicTitle  String
  specialty      String
  supervisions   Supervision[]
}



model Thesis {
  id               String       @id @default(cuid())
  title            String
  studentName      String
  type             ThesisType
  status           ThesisStatus @default(PENDING)
  registrationDate DateTime     @default(now())
  defenseDate      DateTime?
  
  supervisors      Supervision[] 
  createdAt        DateTime     @default(now())
}

model Promotion {
  id            String   @id @default(cuid())
  doctorId      String
  doctor        FacultyDoctor @relation(fields: [doctorId], references: [id])
  oldTitle      String
  newTitle      String
  promotionDate DateTime @default(now())
}
model Notification {
  id        String   @id @default(cuid())
  title     String   
  message   String   
  type      String   @default("info") 
  read      Boolean  @default(false)  
  createdAt DateTime @default(now())
}

model Supervision {
  id                 String         @id @default(cuid())
  thesisId           String
  
  thesis             Thesis         @relation(fields: [thesisId], references: [id], onDelete: Cascade)
  
  doctorId           String?
  doctor             FacultyDoctor? @relation(fields: [doctorId], references: [id])

  externalExaminerId String?
  externalExaminer   ExternalExaminer? @relation(fields: [externalExaminerId], references: [id])

  supervisionRole    String  
}